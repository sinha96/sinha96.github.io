---
permalink: /posts-kb.json
layout: null
sitemap: false
---
[
{% for post in site.posts %}{% capture txt %}{{ post.title }} ({{ post.date | date: "%Y-%m-%d" }}) — {{ post.excerpt | strip_html | strip_newlines | strip }}{% endcapture %}{
  "id": {{ post.slug | jsonify }},
  "section": "Journal",
  "title": {{ post.title | jsonify }},
  "url": {{ post.url | jsonify }},
  "date": {{ post.date | date: "%Y-%m-%d" | jsonify }},
  "tags": {{ post.tags | jsonify }},
  "text": {{ txt | jsonify }}
}{% unless forloop.last %},{% endunless %}
{% endfor %}
]
